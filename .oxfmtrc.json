{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["*.md", "*.min.js", "node_modules/**/*"],
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "overrides": [
    {
      "files": ["*.test.js", "*.spec.js", "*.test.ts", "*.spec.ts"],
      "options": {
        "printWidth": 120
      }
    }
  ]
}
