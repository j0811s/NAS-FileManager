{
  "name": "@nas-fm/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit && esbuild src/server.ts --bundle --platform=node --format=esm --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\" --outfile=dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "2.0.6",
    "@nas-fm/shared": "*",
    "hono": "4.12.27",
    "mime-types": "3.0.2"
  },
  "devDependencies": {
    "@types/mime-types": "3.0.1",
    "@types/node": "26.0.1",
    "esbuild": "0.28.1",
    "tsx": "4.22.4",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
